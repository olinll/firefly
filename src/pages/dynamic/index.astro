---
import { Icon } from "astro-icon/components";
import DynamicCover from "@/components/pages/dynamic/DynamicCover.astro";
import DynamicFeed from "@/components/pages/dynamic/DynamicFeed.svelte";
import DynamicItemTemplate from "@/components/pages/dynamic/DynamicItemTemplate.astro";
import {
	analyticsConfig,
	commentConfig,
	dynamicConfig,
	siteConfig,
} from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import "@/styles/dynamic.css";
import { getCollection } from "astro:content";
import { url } from "@/utils/url-utils";

if (!siteConfig.pages.dynamic) {
	return Astro.redirect("/404/");
}

const title = dynamicConfig.title || i18n(I18nKey.dynamic);
const description =
	dynamicConfig.description || i18n(I18nKey.dynamicDescription);
const itemsPerPage = Math.max(1, dynamicConfig.itemsPerPage ?? 10);
const showInlineComments = Boolean(
	dynamicConfig.showComment !== false &&
		commentConfig.type &&
		commentConfig.type !== "none",
);
const dataUrl = url("/api/dynamic.json");

// Umami 浏览量配置
const umamiCfg = analyticsConfig.umamiAnalytics;
const showUmamiViews = !!umamiCfg?.shareId;
const umamiShareId = umamiCfg?.shareId || "";
const umamiApiBase =
	umamiCfg?.shareApiBase ||
	(umamiCfg?.scriptUrl ? new URL(umamiCfg.scriptUrl).origin : "");

let dynamicCount = 0;
if (dynamicConfig.memos?.serverUrl) {
	try {
		const svr = dynamicConfig.memos.serverUrl.replace(/\/+$/, "");
		const tok = dynamicConfig.memos.accessToken;
		const headers: Record<string, string> = {};
		if (tok) headers.Authorization = `Bearer ${tok}`;
		const r = await fetch(`${svr}/api/v1/memos?pageSize=1000`, { headers });
		if (r.ok) {
			const d = await r.json();
			const tags = dynamicConfig.memos?.tags;
			dynamicCount = (d.memos || []).filter(
				(m: { visibility: string; tags?: string[] }) =>
					(dynamicConfig.memos?.visibility !== "public" ||
						m.visibility === "PUBLIC") &&
					(!tags?.length || tags.some((t) => m.tags?.includes(t))),
			).length;
		}
	} catch {}
} else {
	dynamicCount = (await getCollection("dynamic")).length;
}
---

<MainGridLayout title={title} description={description}>
	<section class="dynamic-page" aria-labelledby="dynamic-page-title">
		{
			dynamicConfig.cover?.enable ? (
				<DynamicCover
					{title}
					{description}
					dynamicCount={dynamicCount}
					showUmamiViews={showUmamiViews}
					umamiShareId={umamiShareId}
					umamiApiBase={umamiApiBase}
				/>
			) : (
				<header class="dynamic-page-header card-base">
					<div class="dynamic-page-heading">
						<div class="dynamic-page-icon" aria-hidden="true">
							<Icon is:inline name="material-symbols:forum-rounded" />
						</div>
						<div>
							<div style="display:flex;align-items:center;gap:0.75rem;flex-wrap:wrap">
								<h2 id="dynamic-page-title">{title}</h2>
							</div>
							{description && <p>{description}</p>}
						</div>
					</div>
					<div class="dynamic-header-end">
						{
							showUmamiViews && (
								<div
									class="dynamic-pv-badge"
									data-umami-pv-path="/dynamic/"
									data-umami-share-id={umamiShareId}
									data-umami-api-base={umamiApiBase}
								>
									<Icon is:inline
										name="material-symbols:visibility-outline-rounded"
										class="dynamic-pv-icon"
									/>
									<span class="dynamic-pv-value" data-umami-pv-value>—</span>
									<span class="dynamic-pv-label">{i18n(I18nKey.pageViews)}</span>
								</div>
							)
						}
						<div
							class="dynamic-count"
							aria-label={`${dynamicCount} ${i18n(I18nKey.dynamic)}`}
						>
							<Icon is:inline name="material-symbols:dynamic-feed-rounded" />
							<strong>{dynamicCount}</strong>
							<span>{i18n(I18nKey.dynamic)}</span>
						</div>
					</div>
					<div class="dynamic-filter">
						<label class="dynamic-search">
							<Icon is:inline name="material-symbols:search-rounded" />
							<input
								type="search"
								data-dynamic-search
								placeholder={i18n(I18nKey.dynamicSearch)}
							/>
						</label>
						<label class="dynamic-year-select">
							<Icon is:inline name="material-symbols:calendar-month-rounded" />
							<select data-year-select aria-label={i18n(I18nKey.year)}>
								<option value="all">{i18n(I18nKey.dynamicAllYears)}</option>
							</select>
							<Icon is:inline name="material-symbols:arrow-drop-down-rounded" />
						</label>
					</div>
				</header>
			)
		}

		<div>
			<DynamicFeed
				client:load
				source={dataUrl}
				{itemsPerPage}
				showComments={showInlineComments}
				emptyText={i18n(I18nKey.dynamicEmpty)}
				noResultsText={i18n(I18nKey.dynamicNoResults)}
				loadingText={i18n(I18nKey.dynamicLoading)}
				allYearsText={i18n(I18nKey.dynamicAllYears)}
				timezone={siteConfig.timezone || "UTC"}
			/>

			<DynamicItemTemplate />

			<script>
				// Umami 浏览量 - 动态页面
				const SHARE_CACHE_KEY = "umami-profile-share";
				const SHARE_CACHE_TTL = 24 * 60 * 60 * 1000;
				const METRICS_CACHE_KEY = "umami-pv-metrics";
				const METRICS_CACHE_TTL = 5 * 60 * 1000;

				async function getShare(apiBase: string, shareId: string) {
					const cached = JSON.parse(localStorage.getItem(SHARE_CACHE_KEY) || "null");
					if (cached && cached.tag === shareId && Date.now() - cached.timestamp < SHARE_CACHE_TTL) return cached.value;
					const resp = await fetch(`${apiBase}/api/share/${shareId}`);
					if (!resp.ok) throw new Error();
					const data = await resp.json();
					localStorage.setItem(SHARE_CACHE_KEY, JSON.stringify({ timestamp: Date.now(), tag: shareId, value: data }));
					return data;
				}

				async function getMetrics(apiBase: string, share: { websiteId: string; token: string }) {
					const cached = JSON.parse(localStorage.getItem(METRICS_CACHE_KEY) || "null");
					if (cached && cached.tag === share.websiteId && Date.now() - cached.timestamp < METRICS_CACHE_TTL) return cached.value;
					const metricsUrl = `${apiBase}/api/websites/${share.websiteId}/metrics?startAt=0&endAt=${Date.now()}&type=path&limit=1000`;
					const resp = await fetch(metricsUrl, {
						headers: { "x-umami-share-token": share.token, "x-umami-share-context": "1" },
					});
					if (!resp.ok) throw new Error();
					const data = await resp.json();
					localStorage.setItem(METRICS_CACHE_KEY, JSON.stringify({ timestamp: Date.now(), tag: share.websiteId, value: data }));
					return data;
				}

				function normalize(p: string) { return p.replace(/\/+$/, "").toLowerCase(); }

				async function fillPageView() {
					const nodes = document.querySelectorAll("[data-umami-pv-path]") as NodeListOf<HTMLElement>;
					if (!nodes.length) return;
					const first = nodes[0];
					const shareId = first.dataset.umamiShareId;
					const apiBase = (first.dataset.umamiApiBase || "").replace(/\/$/, "");
					if (!shareId || !apiBase) return;
					try {
						const share = await getShare(apiBase, shareId);
						const metrics = await getMetrics(apiBase, share);
						const lookup: Record<string, number> = {};
						for (const r of metrics) {
							const key = normalize(r.x);
							lookup[key] = (lookup[key] || 0) + (r.y || 0);
						}
						nodes.forEach((node) => {
							const value = node.querySelector("[data-umami-pv-value]");
							if (!value) return;
							value.textContent = (lookup[normalize(node.dataset.umamiPvPath || "")] || 0).toLocaleString("en-US");
						});
					} catch {
						nodes.forEach((node) => {
							const el = node.querySelector("[data-umami-pv-value]");
							if (el) el.textContent = "—";
						});
					}
				}

				function run() { requestAnimationFrame(() => fillPageView()); }
				run();
				document.addEventListener("swup:contentReplaced", run);
				document.addEventListener("astro:page-load", run);
			</script>
		</div>
	</section>
</MainGridLayout>
